# ============================================
# CDAX Academy - Archivo de configuración
# ============================================
# Copia este archivo como .env y completa los valores
# cp .env.example .env

# ========================
# MODO
# ========================
MODO_DESARROLLO=true

# ========================
# BASE DE DATOS
# ========================
DATABASE_URL=sqlite:///./dental_academia.db
REDIS_URL=redis://localhost:6379

# ========================
# SEGURIDAD
# ========================
# Genera una clave segura en producción:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# ========================
# DOMINIO
# ========================
DOMAIN=localhost:8000

# ========================
# GOOGLE OAuth (opcional)
# ========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ========================
# STRIPE (opcional)
# ========================
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ========================
# BUNNY STREAM & CDN
# ========================
BUNNY_API_KEY=45181e55-43ec-4b34-81d4186fa445-a26a-46f4
BUNNY_LIBRARY_ID=632570
BUNNY_STORAGE_ZONE=cdaxacademy
BUNNY_HOSTNAME=localhost:8000
